{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    ".plasmo/**/*",
    "./**/*.ts",
    "./**/*.tsx",
    "src/**/*",
    "globals.d.ts"
  ],
  "compilerOptions": {
    "paths": {
      "~*": [
        "./src/*"
      ]
    },
    "baseUrl": ".",
    "types": [
      "chrome",
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "ignoreDeprecations": "6.0"
  }
}
